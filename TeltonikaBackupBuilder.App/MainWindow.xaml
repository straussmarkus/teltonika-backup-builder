<Window x:Class="TeltonikaBackupBuilder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Teltonika Backup Builder"
        Icon="/Assets/AppIcon.ico"
        Height="760" Width="1120" MinHeight="700" MinWidth="1000" FontSize="13">
    <Window.Resources>
        <Style x:Key="ModeTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontWeight" Value="Normal" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style x:Key="SubtleGridSplitterStyle" TargetType="GridSplitter" BasedOn="{StaticResource {x:Type GridSplitter}}">
            <Setter Property="Width" Value="4" />
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />
            <Setter Property="Opacity" Value="0.25" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="ShowsPreview" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <TabControl ItemContainerStyle="{StaticResource ModeTabItemStyle}">
            <TabItem Header="Backup duplizieren">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical">
                        <TextBlock Text="Quelle (.tar.gz)" FontWeight="SemiBold" />
                        <DockPanel Margin="0,6,0,0">
                            <Button Content="Auswählen..." Command="{Binding BrowseSourceCommand}" Width="120" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding SourceBackupPath}" IsReadOnly="True" />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,14,0,0">
                        <TextBlock Text="Hostnamen (eine pro Zeile oder mit Komma/Semikolon getrennt)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding HostnamesInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="130" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,14,0,0">
                        <TextBlock Text="Ausgabeordner" FontWeight="SemiBold" />
                        <TextBox Text="{Binding OutputDirectory, Mode=OneWay}" IsReadOnly="True" Margin="0,6,0,0" />
                        <CheckBox Content="Nach dem Erstellen verifizieren (nur /etc/config/system darf abweichen)"
                                  IsChecked="{Binding VerifyAfterCreate}" Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,14,0,0">
                        <TextBlock Text="Protokoll" FontWeight="SemiBold" />
                        <ListBox ItemsSource="{Binding LogEntries}" Margin="0,6,0,0" />
                    </StackPanel>

                    <DockPanel Grid.Row="4" Margin="0,14,0,0" LastChildFill="False">
                        <ProgressBar Width="140" Height="18" IsIndeterminate="{Binding IsBusy}" DockPanel.Dock="Right" Margin="10,0,0,0" />
                        <Button Content="Backups erzeugen" Command="{Binding GenerateCommand}" Width="170" Margin="0,0,8,0" DockPanel.Dock="Right" Style="{StaticResource PrimaryActionButtonStyle}" />
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="REST-API Rebuild">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical">
                        <TextBlock Text="Quelle (.tar.gz) für Analyse und Rebuild-Plan" FontWeight="SemiBold"/>
                        <DockPanel Margin="0,6,0,0">
                            <Button Content="Auswählen..." Command="{Binding BrowseSourceCommand}" Width="120" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding SourceBackupPath}" IsReadOnly="True"/>
                        </DockPanel>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Router-IP / URL" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding RouterIpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Benutzername" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding RouterUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Passwort" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding RouterPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="5*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Backup-Modell" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding BackupModel, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Backup-Firmware" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding BackupFirmware, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Doku (modell-/firmwarebezogener Kandidat)" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding DocumentationUrl, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
                        <ProgressBar Width="140" Height="18" IsIndeterminate="{Binding IsApiBusy}" DockPanel.Dock="Right" Margin="10,0,0,0" />
                        <Button Content="Alle Calls ausführen" Command="{Binding ExecuteAllApiCallsCommand}" Width="170" Margin="8,0,0,0" DockPanel.Dock="Right" Style="{StaticResource PrimaryActionButtonStyle}"/>
                        <Button Content="Ausgewählten Call ausführen" Command="{Binding ExecuteSelectedApiCallCommand}" Width="220" Margin="8,0,0,0" DockPanel.Dock="Right" Style="{StaticResource PrimaryActionButtonStyle}"/>
                        <Button Content="Backup analysieren + Call-Plan erzeugen" Command="{Binding AnalyzeApiPlanCommand}" Width="280" DockPanel.Dock="Right" Style="{StaticResource PrimaryActionButtonStyle}"/>
                    </DockPanel>

                    <Grid Grid.Row="4" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Geplante Calls" Margin="0,0,10,0">
                            <ListView ItemsSource="{Binding ApiCalls}" SelectedItem="{Binding SelectedApiCall}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="#" DisplayMemberBinding="{Binding Order}" Width="40"/>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="260"/>
                                        <GridViewColumn Header="Methode" DisplayMemberBinding="{Binding Method}" Width="70"/>
                                        <GridViewColumn Header="Pfad" DisplayMemberBinding="{Binding Path}" Width="220"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </GroupBox>

                        <GridSplitter Grid.Column="1"
                                      Margin="0,4"
                                      Style="{StaticResource SubtleGridSplitterStyle}" />

                        <Grid Grid.Column="2" Margin="10,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <GroupBox Grid.Row="0" Header="Vollständiger Request" Margin="0,0,0,8">
                                <TextBox Text="{Binding SelectedApiCallRequest, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="Ergebnis (letzte Ausführung)">
                                <TextBox Text="{Binding SelectedApiCallResponse, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <GroupBox Grid.Row="5" Header="REST-API Protokoll" Margin="0,12,0,0">
                        <ListBox ItemsSource="{Binding ApiLogEntries}"/>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
